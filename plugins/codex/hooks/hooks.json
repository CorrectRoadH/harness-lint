{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/plugins/codex/hooks/session-start.sh\"",
            "statusMessage": "Loading harness-lint guidance..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/plugins/codex/hooks/check-changed.sh\"",
            "statusMessage": "Checking harness-lint..."
          }
        ]
      }
    ]
  }
}
