            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/lint-driven-development",
              "concepts/rules",
              "concepts/rule-packs",
              "concepts/configuration"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/writing-rules",
              "guides/managing-packs",
              "guides/ci-integration",
              "guides/ai-agent-setup"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/cli",
              "reference/harness-toml",
              "reference/rule-format",
              "reference/gritql-patterns",
              "reference/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Rule Packs",
        "groups": [
          {
            "group": "Available Packs",
            "pages": [
              "packs/overview",
              "packs/typescript",
              "packs/python",
              "packs/go",
              "packs/rust"
            ]
          }
        ]
      }
    ]
  }
}
