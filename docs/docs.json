{
  "$schema": "https://mintlify.com/docs.json",
  "name": "harness-lint",
  "theme": "luma",
  "colors": {
    "primary": "#2563EB",
    "light": "#DBEAFE",
    "dark": "#1E3A8A"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/CorrectRoadH/harness-lint"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
